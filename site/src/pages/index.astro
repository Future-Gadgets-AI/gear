---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('posts', ({ data }) => data.status !== 'draft')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Layout title="gear">
<h1>gear</h1>
<ul>
{posts.map((post) => (
<li><a href={`${base}/posts/${post.data.slug}/`}>{post.data.title}</a><div>{post.data.date.toISOString().slice(0, 10)}</div>{post.data.tl_dr[0] && <p>{post.data.tl_dr[0]}</p>}</li>
))}
</ul>
</Layout>
